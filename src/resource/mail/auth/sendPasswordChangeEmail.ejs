<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thông báo đổi mật khẩu</title>
  </head>
  <body
    style="
      font-family:
        -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto,
        &quot;Helvetica Neue&quot;, Arial, sans-serif;
      line-height: 1.5;
      color: #1a1a1a;
      margin: 0;
      padding: 0;
      -webkit-font-smoothing: antialiased;
    "
  >
    <div style="max-width: 400px; margin: 0 auto; padding: 20px">
      <h2
        style="
          margin-top: 0;
          margin-bottom: 20px;
          font-size: 24px;
          font-weight: 600;
        "
      >
        Mật khẩu đã được thay đổi
      </h2>

      <p style="margin: 0 0 10px 0">Chào bạn,</p>

      <p style="margin: 0 0 20px 0">
        Mật khẩu tài khoản của bạn vừa được thay đổi thành công vào
        <strong><%= changeTime %></strong>.
      </p>

      <!-- NẾU BẠN LÀ NGƯỜI THỰC HIỆN -->
      <div
        style="
          background-color: #f0f9ff;
          border-left: 4px solid #0066cc;
          padding: 15px;
          margin: 20px 0;
          border-radius: 4px;
        "
      >
        <p style="margin: 0; font-weight: 500">
          ✅ Nếu bạn vừa thực hiện thay đổi này:
        </p>
        <p style="margin: 5px 0 0 0">Bạn có thể bỏ qua email này.</p>
      </div>

      <!-- NẾU KHÔNG PHẢI BẠN -->
      <div
        style="
          background-color: #fff5f5;
          border-left: 4px solid #dc2626;
          padding: 15px;
          margin: 20px 0;
          border-radius: 4px;
        "
      >
        <p style="margin: 0; font-weight: 500">⚠️ Nếu KHÔNG PHẢI bạn:</p>
        <p style="margin: 5px 0 0 0">
          Vui lòng liên hệ ngay với chúng tôi để bảo vệ tài khoản.
        </p>
      </div>

      <!-- THÔNG TIN HỖ TRỢ -->
      <div
        style="
          margin: 30px 0 20px 0;
          padding: 20px;
          background-color: #f9f9f9;
          border-radius: 8px;
        "
      >
        <p style="margin: 0 0 10px 0; font-weight: 500">📞 Cần hỗ trợ?</p>
        <p style="margin: 0 0 5px 0">
          Email:
          <a
            href="mailto:support@company.com"
            style="color: #0066cc; text-decoration: none"
            >support@company.com</a
          >
        </p>
        <p style="margin: 0">
          Hotline: <span style="color: #0066cc">1900 1234</span>
        </p>
      </div>

      <hr style="border: none; border-top: 1px solid #eaeaea; margin: 20px 0" />

      <div style="font-size: 14px; color: #666666">
        <p style="margin: 0 0 10px 0">
          Email này được gửi tự động, vui lòng không trả lời.
        </p>
        <p style="margin: 0">© 2024 Công ty của bạn. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
